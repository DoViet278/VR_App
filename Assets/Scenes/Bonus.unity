  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Ph\u1ED1 c\u1ED5 H\u1ED9i An, di s\u1EA3n v\u0103n h\xF3a th\u1EBF gi\u1EDBi
    \u0111\u01B0\u1EE3c UNESCO c\xF4ng nh\u1EADn, l\xE0 \u0111\xF4 th\u1ECB c\u1ED5
    n\u1EB1m b\xEAn b\u1EDD s\xF4ng Thu B\u1ED3n, t\u1EC9nh Qu\u1EA3ng Nam, c\xE1ch
    \u0110\xE0 N\u1EB5ng 30km. N\u1ED5i ti\u1EBFng v\u1EDBi ki\u1EBFn tr\xFAc nh\xE0
    v\xE0ng, \u0111\xE8n l\u1ED3ng r\u1EF1c r\u1EE1 v\xE0 c\xE1c h\u1ED9i qu\xE1n,
    n\u01A1i \u0111\xE2y mang v\u1EBB \u0111\u1EB9p b\xECnh l\u1EB7ng, r\xEAu phong
    c\u1EE7a m\u1ED9t th\u01B0\u01A1ng c\u1EA3ng qu\u1ED1c t\u1EBF s\u1EA7m u\u1EA5t
    th\u1EBF k\u1EF7 17-18"
  m_isRightToLeft: 0
